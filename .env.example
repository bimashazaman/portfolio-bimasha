# ── Frontend environment (Vite) ──
# Copy this file to .env to override defaults. All values are optional —
# the site works with none of them set.

# Base URL of the content API. Defaults to "/api" (same domain as the site),
# which is correct for the standard Hostinger deploy. Only change this if the
# API lives on a different host (e.g. during local dev against a remote API).
VITE_API_BASE=/api

# Optional: override where the contact form POSTs. By default it posts to
# `${VITE_API_BASE}/contact.php` (your own backend, saved to the DB and shown
# in /admin). Set this to a Formspree / Web3Forms / Basin URL to use one of
# those instead. If any submission fails, the form falls back to a prefilled
# email automatically, so it never dead-ends.
VITE_CONTACT_ENDPOINT=
